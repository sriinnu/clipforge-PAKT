{
  "$schema": "https://raw.githubusercontent.com/nichochar/tauri-apps/tauri-v2/tooling/cli/schema.json",
  "productName": "ClipForge",
  "version": "0.1.0",
  "identifier": "com.yugenlab.clipforge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns"]
  },
  "plugins": {
    "clipboard-manager": { "all": true },
    "global-shortcut": { "all": true },
    "sql": {
      "preload": {
        "db": "sqlite:clipforge.db"
      }
    }
  }
}
