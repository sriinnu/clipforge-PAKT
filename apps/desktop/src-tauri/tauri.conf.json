{
  "productName": "ClipForge PAKT",
  "version": "0.6.2",
  "identifier": "com.sriinnu.clipforge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ClipForge",
        "width": 760,
        "height": 700,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "hiddenTitle": true,
        "shadow": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "\u00a9 2026 Sriinnu",
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"]
  },
  "plugins": {}
}
