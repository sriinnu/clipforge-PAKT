{
  "productName": "ClipForge",
  "version": "0.1.0",
  "identifier": "com.yugenlab.clipforge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ClipForge",
        "width": 400,
        "height": 540,
        "resizable": true,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  },
  "plugins": {
    "clipboard-manager": { "all": true },
    "global-shortcut": { "all": true },
    "sql": {
      "preload": {
        "db": "sqlite:clipforge.db"
      }
    }
  }
}
