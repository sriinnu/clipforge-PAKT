{
  "name": "@sriinnu/pakt",
  "version": "0.4.2",
  "description": "PAKT compression engine — lossless format conversion for LLM token optimization",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "pakt": "./bin/pakt.js"
  },
  "files": ["bin", "dist", "LICENSE", "README.md"],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "bench": "vitest bench",
    "clean": "rm -rf dist"
  },
  "keywords": ["pakt", "compression", "llm", "tokens", "toon", "clipboard"],
  "author": "Srinivas Pendela <sriinnu@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sriinnu/clipforge-PAKT.git",
    "directory": "packages/pakt-core"
  },
  "homepage": "https://github.com/sriinnu/clipforge-PAKT#readme",
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.3.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "gpt-tokenizer": "^2.8.0"
  }
}
