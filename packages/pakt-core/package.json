{
  "name": "@sriinnu/pakt",
  "version": "0.6.2",
  "description": "PAKT compression engine — lossless-first L1-L3 compression with opt-in L4 semantic packing for LLM token optimization",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "pakt": "./bin/pakt.js"
  },
  "files": ["bin", "dist", "LICENSE", "README.md"],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup && node ../../scripts/release/strip-build-artifacts.mjs dist && node ../../scripts/release/verify-no-sourcemaps.mjs dist",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "bench": "vitest bench",
    "clean": "rm -rf dist"
  },
  "keywords": ["pakt", "compression", "llm", "tokens", "clipboard"],
  "author": "Srinivas Pendela <sriinnu@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sriinnu/clipforge-PAKT.git",
    "directory": "packages/pakt-core"
  },
  "homepage": "https://github.com/sriinnu/clipforge-PAKT#readme",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "tsup": "^8.5.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "gpt-tokenizer": "^2.9.0",
    "zod": "^4.3.6"
  }
}
