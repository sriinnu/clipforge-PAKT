{
  "name": "@sriinnu/clipforge-pakt",
  "private": true,
  "author": "Srinivas Pendela <sriinnu@users.noreply.github.com>",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "build:all": "turbo run build",
    "build:core": "pnpm --filter @sriinnu/pakt build",
    "build:playground": "pnpm --filter @sriinnu/clipforge-playground build",
    "build:extension": "pnpm --filter @sriinnu/clipforge-extension build",
    "build:desktop:web": "pnpm --filter @sriinnu/clipforge-desktop build",
    "build:desktop": "pnpm --filter @sriinnu/clipforge-desktop tauri build",
    "build:apps": "pnpm build:playground && pnpm build:extension && pnpm build:desktop:web",
    "test": "turbo run test",
    "test:core": "pnpm --filter @sriinnu/pakt test",
    "test:playground": "pnpm --filter @sriinnu/clipforge-playground test",
    "test:watch": "turbo run test:watch",
    "bench": "turbo run bench",
    "bench:snapshot": "pnpm --filter @sriinnu/pakt build && node scripts/release/generate-benchmark-snapshot.mjs",
    "dev:playground": "pnpm --filter @sriinnu/clipforge-playground dev",
    "dev:extension": "pnpm --filter @sriinnu/clipforge-extension dev",
    "dev:desktop:web": "pnpm --filter @sriinnu/clipforge-desktop dev",
    "dev:desktop": "pnpm --filter @sriinnu/clipforge-desktop tauri dev",
    "start:mcp": "pnpm --filter @sriinnu/pakt build && node packages/pakt-core/dist/cli.js serve --stdio",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "turbo run clean && rm -rf node_modules",
    "nuke": "find . -name 'node_modules' -not -path '*/.git/*' -prune -exec rm -rf {} + ; find . -name 'dist' -not -path '*/.git/*' -not -path '*/node_modules/*' -prune -exec rm -rf {} + ; find . -name 'target' -not -path '*/.git/*' -not -path '*/node_modules/*' -prune -exec rm -rf {} + ; rm -rf .turbo",
    "fresh": "pnpm nuke && pnpm install && pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^25.2.3",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  }
}
